AR0_subsetted_lists = [[(key, value)] for key, value in AR0_dict.items()]

AR0_ratios = {}

for sublist in AR0_subsetted_lists:
    key, values = sublist[0]  

    under = sum(v for v in values if v <= 1)
    total = sum(values)

    ratio = under / total 
    AR0_ratios[key] = ratio

